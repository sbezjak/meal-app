---
import Base from '../layouts/Base.astro';
import recipes from '../data/recipes.json';
import weeks from '../data/weeks.json';
import categories from '../data/categories.json';
---
<Base title="The Kitchen — Sara's Meal Prep">
  <div class="topbar">
    <div class="inner">
      <div class="brand"><span class="bdot"></span>Sara's Kitchen</div>
      <nav>
        <button class="tab active" data-view="mine">My Week</button>
        <button class="tab" data-view="recipes">Recipes</button>
        <button class="tab" data-view="shop">Shopping</button>
      </nav>
    </div>
  </div>

  <div class="wrap">
    <section class="view active" id="view-mine">
      <div class="mine-intro">🧑‍🍳 <b>Build your week.</b> Two ways — both fill the same shopping list. <b>Pick recipes</b> you fancy, or go <b>From what I have</b> and let it suggest what you can cook right now.</div>
      <div class="mine-modes">
        <button data-mmode="pick" class="active">🧺 Pick recipes</button>
        <button data-mmode="stock">🔎 From what I have</button>
      </div>
      <div id="minePick" class="mmode-panel">
        <input id="pickSearch" class="search" type="text" placeholder="🔎 Search a recipe to add…" autocomplete="off" />
        <div id="pickResults" class="pick-results"></div>
      </div>
      <div id="mineStock" class="mmode-panel" hidden>
        <div class="stock-note">Tell it what you’ve got — type it in, or pull everything you ticked off in Shopping — and it shows what you can cook now.</div>
        <div class="mine-add">
          <input id="haveInput" list="haveOpts" type="text" placeholder="Add an ingredient you have…" autocomplete="off" />
          <button id="haveAddBtn">＋ Add</button>
        </div>
        <datalist id="haveOpts"></datalist>
        <div class="stock-tools">
          <button class="toolbtn" id="pullBasketBtn">⬇ Pull from my basket</button>
          <button class="toolbtn" id="clearHaveBtn">Clear</button>
        </div>
        <div id="haveChips" class="chips"></div>
        <div id="stockSuggest"></div>
      </div>
      <div class="mine-yourweek-h">Your week — Mon to Sun</div>
      <div id="mineList"></div>
      <button class="viewshop" id="mineShop">🛒 Shopping for my week →</button>
    </section>

    <section class="view" id="view-recipes">
      <input class="search" id="recipeSearch" type="text" placeholder="Search recipes or ingredients…" autocomplete="off" />
      <div class="filters" id="filters"></div>
      <div id="recipeList"></div>
    </section>

    <section class="view" id="view-shop">
      <div class="shophead">
        <h2 id="shopTitle"></h2>
        <button class="copybtn" id="copyBtn">📋 Copy list</button>
      </div>
      <div class="scopebar" id="scopeBar">
        <button data-scope="mine">My week</button>
        <button data-scope="all">Whole rotation</button>
      </div>
      <div class="addrow">
        <input id="addInput" type="text" placeholder="Add your own item…" autocomplete="off" />
        <button id="addBtn">Add</button>
      </div>
      <div class="toolbar">
        <button class="toolbtn" id="uncheckBtn">Uncheck all</button>
        <button class="toolbtn" id="clearAddedBtn">Clear added items</button>
      </div>
      <div id="shopContent"></div>
      <textarea class="copyhidden" id="copyArea" readonly aria-hidden="true" tabindex="-1"></textarea>
    </section>
  </div>

  <script is:inline define:vars={{ recipes, weeks, categories }}>
    const R = {};
    recipes.forEach(r => { R[r.id] = r; });
    const CAT = categories;
    const CAT_ORDER = Object.keys(CAT);
    const AISLE_ORDER = ['Produce','Meat & tofu','Dairy & eggs','Frozen','Grains & carbs','Bakery','Cans & jars','Sauces & oils','Spices & dried herbs','Pantry','Other'];
    const TAG = { cook:{t:'Cook fresh',c:'var(--accent)'}, fridge:{t:'Leftovers',c:'#6c8fb0'}, freezer:{t:'From freezer',c:'var(--vegan)'}, takeout:{t:'Takeout',c:'var(--takeout)'} };

    const REFS = [
      ['mushroom sauce','mushroom_sauce'], ['cream sauce','cream'], ['marinara','marinara'],
      ['peanut','peanut'], ['breaded','breaded'], ['burger sauce','burgersauce'],
      ['yoghurt','yogsauce'], ['cheese bread','dough'],
    ];
    const resolveRef = (item) => { const l=item.toLowerCase(); for(const [m,id] of REFS) if(l.includes(m)) return id; return null; };

    const LS = {
      get(k, fb){ try { const v = localStorage.getItem(k); return v==null ? fb : JSON.parse(v); } catch(e){ return fb; } },
      set(k, v){ try { localStorage.setItem(k, JSON.stringify(v)); } catch(e){} },
    };

    let currentWeek = LS.get('week', 0);
    if (typeof currentWeek !== 'number' || currentWeek < 0 || currentWeek >= weeks.length) currentWeek = 0;

    // One-time: checks used to live in per-scope stores (shop:checks:all, shop:checks:week:N).
    // Merge any of those into the single shared store so existing baskets aren't lost.
    if(!LS.get('shop:checksMerged', false)){
      const merged = LS.get('shop:checks', {});
      for(let i=0;i<localStorage.length;i++){
        const k = localStorage.key(i);
        if(k && k.startsWith('shop:checks:')) Object.assign(merged, LS.get(k, {}));
      }
      LS.set('shop:checks', merged);
      LS.set('shop:checksMerged', true);
    }

    const isFreeDay = (d) => d.tag === 'takeout';
    const breakfastIds = (w) => Array.isArray(w.breakfast) ? w.breakfast : [w.breakfast];
    // Shopping derives from every day that has a real recipe (incl. a named weekend "treat" takeout) + the week's breakfasts.
    // A pure free day (no recipe id) adds nothing.
    const plannedRecipeIds = (w) => [...new Set([...w.days.map(d=>d.id).filter(id=>R[id]), ...breakfastIds(w)])];

    const ingLine = (i) => `<li>${i.item}${i.qty && i.qty!=='—' ? ` — <span class="q">${i.qty}</span>` : ''}</li>`;

    // Ingredient list — grouped into labelled sub-sections when items carry a `group` (e.g. snacks by craving).
    function ingredientsHTML(r){
      const normal = r.ingredients.filter(i => !i.item.startsWith('→'));
      if(normal.some(i => i.group)){
        const groups = [...new Set(normal.map(i => i.group))];
        return groups.map(g =>
          `<h5>${g}</h5><ul>` + normal.filter(i => i.group===g).map(ingLine).join('') + '</ul>'
        ).join('');
      }
      return '<ul>' + normal.map(ingLine).join('') + '</ul>';
    }

    function refsOf(r){
      const out=[]; const seen=new Set();
      r.ingredients.forEach(i => { if(i.item.startsWith('→')){ const id=resolveRef(i.item); if(id && R[id] && !seen.has(id)){ seen.add(id); out.push({ label:i.item.replace(/^→\s*/,''), rec:R[id] }); } } });
      return out;
    }
    function detailHTML(r){
      const refs = refsOf(r);
      let h = '<div class="rdetail"><h4>Ingredients</h4>';
      h += ingredientsHTML(r);
      if(refs.length) h += '<ul>' + refs.map(x => `<li>+ ${x.label} <span class="q">(recipe below)</span></li>`).join('') + '</ul>';
      h += '<h4>Method</h4><ol>' + r.steps.map(s => `<li>${s}</li>`).join('') + '</ol>';
      // Embedded sub-recipes (sauces etc.) — full text shown inline, so no separate "open full recipe" link.
      refs.forEach(x => {
        const sr = x.rec;
        h += `<div class="saucebox"><div class="sx">${sr.title}</div>`
          + ingredientsHTML(sr)
          + '<ol>' + sr.steps.map(s=>`<li>${s}</li>`).join('') + '</ol></div>';
      });
      if(r.tip) h += `<div class="tip">💡 ${r.tip}</div>`;
      h += '</div>';
      return h;
    }

    // ===== RECIPES =====
    let activeFilter = 'all';
    let searchQ = '';
    function renderFilters(){
      const f = document.getElementById('filters');
      let html = `<button data-f="all" style="background:var(--accent);border-color:var(--accent);color:#fff">All</button>`;
      for(const k in CAT) html += `<button data-f="${k}">${CAT[k].label}</button>`;
      f.innerHTML = html;
      f.querySelectorAll('button').forEach(b => {
        b.onclick = () => {
          activeFilter = b.dataset.f;
          f.querySelectorAll('button').forEach(x => { x.style.background='var(--card)'; x.style.borderColor='var(--line)'; x.style.color='var(--muted)'; });
          const col = b.dataset.f==='all' ? 'var(--accent)' : CAT[b.dataset.f].color;
          b.style.background=col; b.style.borderColor=col; b.style.color='#fff';
          renderRecipes();
        };
      });
    }
    function matchesSearch(r){
      if(!searchQ) return true;
      const hay = (r.title + ' ' + r.ingredients.map(i=>i.item).join(' ')).toLowerCase();
      return hay.includes(searchQ);
    }
    function renderRecipes(){
      const list = document.getElementById('recipeList');
      const mine = new Set(getMyWeek());
      let entries = recipes.filter(r => (activeFilter==='all' || r.category===activeFilter) && matchesSearch(r));
      const showHeads = activeFilter==='all' && !searchQ;
      if(activeFilter==='all') entries = entries.slice().sort((a,b)=>CAT_ORDER.indexOf(a.category)-CAT_ORDER.indexOf(b.category));
      if(!entries.length){ list.innerHTML = '<p style="color:var(--muted)">No recipes match.</p>'; return; }
      let lastCat = null;
      list.innerHTML = entries.map(r => {
        let head='';
        if(showHeads && r.category!==lastCat){ lastCat=r.category; head=`<div class="sectionhead">${CAT[r.category].label}</div>`; }
        return head + `<div class="recipe-card" data-rid="${r.id}">
          <div class="head" data-toggle="card">
            <span class="dot" style="background:${CAT[r.category].color}"></span>
            <span class="title">${r.title}</span>
            <span class="pt">${r.portions}</span>
            <span class="chev">▸</span>
          </div>
          <div class="body"><button class="minebtn${mine.has(r.id)?' on':''}" data-addmine="${r.id}">${mine.has(r.id)?'✓ In my week':'＋ Add to my week'}</button>${detailHTML(r)}</div>
        </div>`;
      }).join('');
    }

    // ===== MY WEEK (experiment) =====
    // A hand-picked set of recipe ids, persisted like the shopping checkboxes, that drives its own
    // shopping scope. Lives alongside the fixed rotation rather than replacing it.
    // My Week is a Mon→Sun planner: `myweekDays` = 7 slots, each a recipeId or null (free day). A meal
    // can sit on two days (e.g. chicken & gravy Mon+Tue); shopping de-dupes (uniqMyWeek) since one batch
    // covers both, so adding a day never changes what you buy. Older flat `myweek` lists are migrated in.
    const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    function getWeekDays(){
      let a = LS.get('myweekDays', null);
      if(!Array.isArray(a)){ const old = LS.get('myweek', []); a = Array.isArray(old) ? old.slice(0,7) : []; }
      a = a.slice(0,7); while(a.length<7) a.push(null);
      return a.map(id => (id && R[id]) ? id : null);
    }
    const setWeekDays = (a) => LS.set('myweekDays', a.slice(0,7));
    const getMyWeek = () => getWeekDays().filter(Boolean);   // assigned recipe ids (membership tests)
    const uniqMyWeek = () => [...new Set(getMyWeek())];        // de-duped — for shopping
    const countInWeek = (id) => getWeekDays().filter(x => x === id).length;
    const inWeek = (id) => getWeekDays().includes(id);
    function addRecipeToWeek(id, target){
      const a = getWeekDays();
      const i = (target!=null && a[target]==null) ? target : a.indexOf(null);
      if(i<0) return false;                                   // week full — all 7 days taken
      a[i] = id; setWeekDays(a); return true;
    }
    function clearDay(i){ const a = getWeekDays(); a[i] = null; setWeekDays(a); }
    function moveDay(i, dir){ const a = getWeekDays(); const j = i+dir; if(j<0||j>6) return; [a[i],a[j]] = [a[j],a[i]]; setWeekDays(a); }
    function removeRecipeFromWeek(id){ setWeekDays(getWeekDays().map(x => x===id ? null : x)); } // clears every day it's on
    function toggleMyWeek(id){ if(inWeek(id)){ removeRecipeFromWeek(id); return false; } return addRecipeToWeek(id); }
    let fillTarget = null;   // a free day chosen via its "＋ add"; the next picked recipe fills exactly it
    // Live recipe search for the "Pick recipes" mode — type → matching recipes (not already picked)
    // show as tappable rows → tap to drop straight into My Week. Replaces the old grouped dropdown.
    let pickQ = '';
    function renderPickResults(){
      const box = document.getElementById('pickResults');
      if(!box) return;
      let rs = recipes.slice();
      if(pickQ){
        rs = rs.filter(r => (r.title + ' ' + r.ingredients.map(i=>i.item).join(' ')).toLowerCase().includes(pickQ));
      } else {
        rs = rs.sort((a,b)=>CAT_ORDER.indexOf(a.category)-CAT_ORDER.indexOf(b.category));
      }
      if(!rs.length){ box.innerHTML = `<div class="mine-empty" style="padding:10px">No recipes match.</div>`; return; }
      box.innerHTML = rs.slice(0, pickQ ? 50 : 8).map(r => {
        const n = countInWeek(r.id);
        return `<button class="pick-row" data-pickadd="${r.id}">
          <span class="dot" style="background:${CAT[r.category].color}"></span>
          <span class="title">${r.title}</span>
          ${n ? `<span class="inweek">×${n} day${n>1?'s':''}</span>` : `<span class="pt">${r.portions}</span>`}
          <span class="plus">＋</span>
        </button>`;
      }).join('');
    }
    function renderMine(){
      renderPickResults();
      const days = getWeekDays();
      const list = document.getElementById('mineList');
      list.innerHTML = days.map((id, i) => {
        if(!id){
          const tgt = fillTarget===i;
          return `<div class="day-slot free${tgt?' target':''}">
            <span class="day-label">${DAYS[i]}</span>
            <span class="day-free">${tgt?'Pick a recipe above ↑':'Free day'}</span>
            <button class="day-add" data-fillday="${i}">＋ add</button>
          </div>`;
        }
        const r = R[id]; const c = CAT[r.category];
        return `<div class="recipe-card mine-card day-slot" data-rid="${id}">
          <div class="head" data-toggle="card">
            <span class="day-label">${DAYS[i]}</span>
            <span class="dot" style="background:${c.color}"></span>
            <span class="title">${r.title}</span>
            <span class="day-move">
              <button class="dmove" data-moveday="${i}|-1"${i===0?' disabled':''} aria-label="Move earlier">▲</button>
              <button class="dmove" data-moveday="${i}|1"${i===6?' disabled':''} aria-label="Move later">▼</button>
            </span>
            <button class="rmmine" data-clearday="${i}" aria-label="Clear this day">✕</button>
            <span class="chev">▸</span>
          </div>
          <div class="body">${detailHTML(r)}</div>
        </div>`;
      }).join('');
    }
    // ===== FROM WHAT I HAVE (reverse-flow experiment) =====
    // Start from ingredients on hand → rank recipes by how much they're covered → tap to add to My Week.
    // Pantry staples (spices, oil, salt…) are ignored for matching, or they'd "match" everything.
    const STAPLE_RE = /\b(oil|salt|pepper|water|sugar|flour|baking powder|baking soda|cornflour|cornstarch|stock cube)\b/i;
    const isStaple = (name, aisle) => aisle === 'Spices & dried herbs' || STAPLE_RE.test(name);
    function recipeMainNames(r){
      const out = new Set();
      r.ingredients.forEach(ing => {
        if(ing.item.startsWith('→')) return; // skip cross-refs — keep the matcher simple
        shopNames(ing).forEach(n => { if(n && !isNoShop(n) && !isStaple(n, ing.aisle || '')) out.add(n); });
      });
      return [...out];
    }
    // Computed lazily on first use: it depends on shopping helpers (isNoShop, shopNames…) declared
    // further down, so building it eagerly here would hit the temporal dead zone and blank the page.
    let _allHaveNames;
    const allHaveNames = () => (_allHaveNames ??= [...new Set(recipes.flatMap(recipeMainNames))].sort((a,b)=>a.localeCompare(b)));

    const getPantry = () => { const a = LS.get('pantry', []); return Array.isArray(a) ? a : []; };
    function addPantry(name){ name = (name||'').trim(); if(!name) return; const a = getPantry(); if(!a.some(x => x.toLowerCase()===name.toLowerCase())) a.push(name); LS.set('pantry', a); }
    function removePantry(name){ LS.set('pantry', getPantry().filter(x => x !== name)); }
    function pantryFromBasket(){
      const checks = LS.get('shop:checks', {}); const a = getPantry(); const have = new Set(a.map(x => x.toLowerCase()));
      Object.keys(checks).forEach(id => {
        if(!checks[id]) return;
        const name = (id.split('|')[1] || id).trim();
        if(name && !have.has(name)){ have.add(name); a.push(name.charAt(0).toUpperCase() + name.slice(1)); }
      });
      LS.set('pantry', a);
    }
    function matchRecipes(have){
      const haveL = have.map(h => h.toLowerCase().trim()).filter(Boolean);
      const covered = name => { const n = name.toLowerCase(); return haveL.some(h => n.includes(h) || h.includes(n)); };
      return recipes.map(r => {
        const main = recipeMainNames(r);
        if(!main.length) return null;
        const miss = main.filter(n => !covered(n));
        return { r, total: main.length, cov: main.length - miss.length, miss };
      }).filter(x => x && x.cov > 0)
        .sort((a,b) => a.miss.length - b.miss.length || b.cov - a.cov || a.r.title.localeCompare(b.r.title));
    }
    function renderStock(){
      const have = getPantry();
      document.getElementById('haveChips').innerHTML = have.length
        ? have.map(h => `<span class="chip">${h}<button data-rmhave="${encodeURIComponent(h)}" aria-label="Remove">✕</button></span>`).join('')
        : '<span class="mine-empty" style="padding:6px">Nothing yet — add what you’ve got, or pull from your basket.</span>';
      const sug = document.getElementById('stockSuggest');
      if(!have.length){ sug.innerHTML = ''; return; }
      const matches = matchRecipes(have);
      if(!matches.length){ sug.innerHTML = '<div class="mine-empty">Nothing matches yet — add a few more items.</div>'; return; }
      const mine = new Set(getMyWeek());
      const makeable = matches.filter(m => m.miss.length === 0);
      let html = makeable.length ? `<button class="addall" id="addAllMakeable">＋ Add all ${makeable.length} I can make now</button>` : '';
      html += matches.slice(0, 12).map(m => {
        const inW = mine.has(m.r.id);
        const status = m.miss.length === 0
          ? '<span class="cov ok">✓ have it all</span>'
          : `<span class="cov">missing ${m.miss.length}: ${m.miss.slice(0,3).join(', ')}${m.miss.length>3?'…':''}</span>`;
        return `<div class="suggest ${m.miss.length===0?'can':''}">
          <span class="s-title" data-goto="${m.r.id}">${m.r.title}</span>
          ${status}
          <button class="minebtn${inW?' on':''}" data-addmine="${m.r.id}">${inW?'✓ added':'＋ add'}</button>
        </div>`;
      }).join('');
      sug.innerHTML = html;
    }
    function setMineMode(m){
      if(m!=='pick' && m!=='stock') m = 'pick';
      document.querySelectorAll('.mine-modes button').forEach(b => b.classList.toggle('active', b.dataset.mmode===m));
      document.getElementById('minePick').hidden = m !== 'pick';
      document.getElementById('mineStock').hidden = m !== 'stock';
      LS.set('mineMode', m);
    }
    function gotoRecipe(id){
      activeFilter='all'; searchQ=''; document.getElementById('recipeSearch').value='';
      renderFilters();
      const ab = document.querySelector('#filters button[data-f="all"]');
      if(ab){ ab.style.background='var(--accent)'; ab.style.borderColor='var(--accent)'; ab.style.color='#fff'; }
      renderRecipes();
      switchTab('recipes');
      const card = document.querySelector(`.recipe-card[data-rid="${id}"]`);
      if(card){ card.classList.add('open'); card.scrollIntoView({behavior:'smooth', block:'start'}); }
    }

    // ===== SHOPPING =====
    // Spice/herb lines are written as blends ("Smoked paprika, onion powder, salt"). For shopping we split them
    // into individual jars, strip amounts, and normalise a few synonyms so the aisle isn't full of overlapping blends.
    const SPICE_ALIAS = { 'ground onion':'onion powder', 'black pepper':'pepper', 'paprika':'sweet paprika', 'dried dill':'dill' };
    const isNoShop = n => /^(warm |cold |hot |luke ?warm )?water$/i.test(n.trim()); // tap water — never put it on the list
    function cleanSpice(tok){
      let s = tok.toLowerCase()
        .replace(/(¼|½|¾|⅓|⅔|\d+(?:\.\d+)?)\s*(tsp|tbsp|teaspoons?|tablespoons?|cups?|g)\b/g, '')
        .replace(/\b(optional|pinch|a little|to taste|generous|of)\b/g, '')
        .replace(/\s+/g, ' ').trim();
      s = SPICE_ALIAS[s] || s;
      return s ? s.charAt(0).toUpperCase() + s.slice(1) : s;
    }
    // The shopping name(s) for one ingredient: spice blends explode into individual items; everything else is a
    // single name from `buy` (explicit canonical name) or the item with any trailing "(note)" stripped.
    function shopNames(ing){
      if((ing.aisle || '') === 'Spices & dried herbs' && !ing.buy)
        return ing.item.split(/[;,]/).map(cleanSpice).filter(Boolean);
      // An explicit `buy` is a deliberate canonical name — keep it verbatim; only strip "(notes)" off raw item text.
      return [ ing.buy ? ing.buy.trim() : ing.item.replace(/\s*\([^)]*\)\s*$/, '').trim() ];
    }
    // Total a list of raw amounts ("400–500 g", "1 tbsp", "for 2", "handful") into one buy-this-much string.
    // Sums each unit it understands (g/kg, ml/l, tbsp/tsp, plain counts, "for N" portions) carrying ranges
    // through; anything it can't parse (handful, to taste…) becomes a trailing "+" meaning "a bit more on top".
    function sumQty(list){
      if(!list || !list.length) return '';
      const tot = {}; const vague = new Set();
      const addU = (u, lo, hi) => { (tot[u] ||= {lo:0, hi:0}); tot[u].lo += lo; tot[u].hi += hi; };
      const toNum = s => { s = String(s).replace(',', '.'); const f = s.match(/^(\d+(?:\.\d+)?)\s*\/\s*(\d+(?:\.\d+)?)$/); return f ? (+f[1])/(+f[2]) : parseFloat(s); };
      list.forEach(raw => {
        let s = String(raw).toLowerCase()
          .replace(/\([^)]*\)/g, ' ').replace(/[~≈]/g, '')
          .replace(/½/g,'0.5').replace(/¼/g,'0.25').replace(/¾/g,'0.75').replace(/⅓/g,'0.33').replace(/⅔/g,'0.67')
          .trim();
        let m = s.match(/for\s+(\d+(?:\.\d+)?)(?:\s*[–-]\s*(\d+(?:\.\d+)?))?/);
        if(m){ addU('portions', +m[1], m[2]?+m[2]:+m[1]); return; }
        m = s.match(/^(\d+(?:[.,]\d+)?(?:\s*\/\s*\d+)?)\s*(?:[–-]\s*(\d+(?:[.,]\d+)?))?\s*(kg|g|ml|l|tbsp|tsp|teaspoons?|tablespoons?)?/);
        if(m && m[1]){
          let lo = toNum(m[1]), hi = m[2] ? toNum(m[2]) : lo, u = m[3] || '';
          if(u==='kg'){ lo*=1000; hi*=1000; u='g'; }
          else if(u==='l'){ lo*=1000; hi*=1000; u='ml'; }
          else if(/^t(sp|easpoon)/.test(u)){ lo/=3; hi/=3; u='tbsp'; }
          else if(/^t(bsp|ablespoon)/.test(u)){ u='tbsp'; }
          else if(!u){ u='ct'; }
          if(!isNaN(lo)){ addU(u, lo, hi); return; }
        }
        if(s) vague.add(s);
      });
      const rng = (lo, hi, unit, round) => { const a = round(lo), b = round(hi); return (a===b ? String(a) : a+'–'+b) + unit; };
      const r0 = n => Math.round(n), r1 = n => Math.round(n*10)/10, rHalf = n => Math.round(n*2)/2;
      const parts = [];
      if(tot.g){ const {lo,hi}=tot.g; parts.push(hi>=1000 ? rng(lo/1000,hi/1000,' kg',r1) : rng(lo,hi,' g',r0)); }
      if(tot.ml){ const {lo,hi}=tot.ml; parts.push(hi>=1000 ? rng(lo/1000,hi/1000,' l',r1) : rng(lo,hi,' ml',r0)); }
      if(tot.tbsp){ const {lo,hi}=tot.tbsp; parts.push(rng(lo,hi,' tbsp',rHalf)); }
      if(tot.ct){ const {lo,hi}=tot.ct; parts.push(rng(lo,hi,'',r0)); }
      if(tot.portions){ const {lo,hi}=tot.portions; parts.push('for ' + (lo===hi ? r0(lo) : r0(lo)+'–'+r0(hi))); }
      let out = parts.join(' + ');
      if(vague.size) out = out ? out + ' +' : (vague.has('as needed') ? 'as needed' : 'some');
      return out;
    }
    function gatherIngredients(recipeIds){
      const map = new Map(); const visited = new Set();
      function add(r){
        if(!r || visited.has(r.id)) return;
        visited.add(r.id);
        r.ingredients.forEach(ing => {
          if(ing.item.startsWith('→')){ const id=resolveRef(ing.item); if(id) add(R[id]); return; }
          const names = shopNames(ing);
          names.forEach(name => {
            if(isNoShop(name)) return;
            const key = name.toLowerCase();
            if(!map.has(key)) map.set(key, { item: name, qtys: [], aisle: ing.aisle || 'Other' });
            // Keep every amount (with repeats) so the shopping list can total them. A blend's qty is
            // meaningless once split, so only carry it when the line maps to a single item.
            if(names.length === 1 && ing.qty && ing.qty !== '—') map.get(key).qtys.push(ing.qty);
          });
        });
      }
      recipeIds.forEach(id => add(R[id]));
      return [...map.values()].map(v => ({ item:v.item, qtys:v.qtys, aisle:v.aisle }));
    }
    // Shopping scope: stock up for one week, or the whole rotation (master list).
    let shopScope = LS.get('shopScope', 'mine');
    if(!['mine','all'].includes(shopScope)) shopScope = 'mine';
    function scopeWeeks(){
      if(shopScope==='all') return weeks.map((_,i)=>i);
      return [currentWeek];
    }
    const manualKey = () => 'shop:manual:' + (shopScope==='mine' ? 'mine' : currentWeek);
    // Checks are shared across every week and the master list, keyed by item id (aisle|name),
    // so once you tick something off it stays ticked wherever that item shows up.
    const checkKey = () => 'shop:checks';
    const itemId = (it) => (it.aisle+'|'+it.item).toLowerCase();

    function buildShop(){
      const byId = new Map();
      const bump = (i, wi, added) => {
        const id = itemId(i);
        if(!byId.has(id)) byId.set(id, { item:i.item, aisle:i.aisle, qtys:[], wks:new Set(), added:false });
        const e = byId.get(id);
        const qs = i.qtys || (i.qty!=null && i.qty!=='' ? [i.qty] : []);
        qs.forEach(q => e.qtys.push(q));
        e.wks.add(wi);
        if(added) e.added = true;
      };
      if(shopScope==='mine'){
        gatherIngredients(uniqMyWeek()).forEach(i => bump(i, 0, false));
        LS.get('shop:manual:mine', []).forEach(i => bump(i, 0, true));
      } else {
        scopeWeeks().forEach(wi => {
          gatherIngredients(plannedRecipeIds(weeks[wi])).forEach(i => bump(i, wi, false));
          LS.get('shop:manual:'+wi, []).forEach(i => bump(i, wi, true));
        });
      }
      const items = [...byId.values()].map(e => ({ item:e.item, aisle:e.aisle, qty:sumQty(e.qtys), weeks:e.wks.size, added:e.added }));
      const groups = {};
      items.forEach(i => { (groups[i.aisle] ||= []).push(i); });
      const order = Object.keys(groups).sort((a,b)=>{ const ai=AISLE_ORDER.indexOf(a),bi=AISLE_ORDER.indexOf(b); return (ai<0?99:ai)-(bi<0?99:bi); });
      order.forEach(a => groups[a].sort((x,y)=>x.item.localeCompare(y.item)));
      return { order, groups };
    }
    function scopeTitle(){
      if(shopScope==='all') return 'Master list — whole rotation';
      if(shopScope==='mine') return 'My week — Shopping';
      return `${weeks[currentWeek].name} — Shopping`;
    }
    let shopBasketOpen = false; // the bottom "In the basket" section starts collapsed so only to-buy items show
    function renderShop(){
      document.getElementById('shopTitle').textContent = scopeTitle();
      document.querySelectorAll('#scopeBar button').forEach(b => b.classList.toggle('active', b.dataset.scope===shopScope));
      const { order, groups } = buildShop();
      const checks = LS.get(checkKey(), {});
      const itemHTML = (i, done) => {
        const id = itemId(i);
        return `<div class="shopitem ${done?'done':''}" data-id="${id}">
            <span class="box">✓</span>
            <span class="txt">${i.item}${i.added?'<span class="added-tag">added</span>':''}${i.weeks>1?`<span class="wk-tag">×${i.weeks} wks</span>`:''}</span>
            <span class="amt">${i.qty||''}</span>
            ${i.added?`<button class="rm" data-rm="${id}" aria-label="Remove">✕</button>`:''}</div>`;
      };
      let html=''; const basket=[];
      order.forEach(aisle => {
        const todo = [];
        groups[aisle].forEach(i => (checks[itemId(i)] ? basket : todo).push(i));
        if(todo.length){
          html += `<div class="shopgroup"><div class="gh">${aisle}</div>`;
          todo.forEach(i => { html += itemHTML(i, false); });
          html += `</div>`;
        }
      });
      if(!html && !basket.length) html = '<p style="color:var(--muted)">Nothing here yet.</p>';
      else if(!html) html = '<p class="shop-alldone">🎉 Everything ticked off!</p>';
      if(basket.length){
        basket.sort((a,b)=>a.item.localeCompare(b.item));
        html += `<div class="shopgroup basket ${shopBasketOpen?'open':''}">
          <button class="basket-h" data-basket>✓ In the basket <span class="basket-n">${basket.length}</span><span class="basket-chev">▾</span></button>
          <div class="basket-items">${basket.map(i => itemHTML(i, true)).join('')}</div>
        </div>`;
      }
      document.getElementById('shopContent').innerHTML = html;
      document.getElementById('copyArea').value = shopText();
    }
    function shopText(){
      const { order, groups } = buildShop();
      const lines = [`${scopeTitle()} list`, ''];
      order.forEach(aisle => {
        lines.push(aisle.toUpperCase());
        groups[aisle].forEach(i => lines.push(`- ${i.item}${i.qty ? ` (${i.qty})` : ''}${i.weeks>1?` ×${i.weeks} wks`:''}`));
        lines.push('');
      });
      return lines.join('\n').trim();
    }
    function toggleCheck(id){ const c=LS.get(checkKey(),{}); if(c[id]) delete c[id]; else c[id]=true; LS.set(checkKey(),c); }
    function addManual(items){ const m=LS.get(manualKey(),[]); const have=new Set(m.map(itemId)); items.forEach(i=>{ if(!have.has(itemId(i))){ m.push(i); have.add(itemId(i)); } }); LS.set(manualKey(),m); }
    function removeManual(id){ const keys = shopScope==='mine' ? ['shop:manual:mine'] : scopeWeeks().map(wi=>'shop:manual:'+wi); keys.forEach(k => LS.set(k, LS.get(k,[]).filter(i=>itemId(i)!==id))); const c=LS.get(checkKey(),{}); delete c[id]; LS.set(checkKey(),c); }

    function copyText(text, btn, label){
      const done = () => { btn.textContent='✓ Copied'; btn.classList.add('ok'); setTimeout(()=>{ btn.textContent=label; btn.classList.remove('ok'); }, 1600); };
      if(navigator.clipboard && navigator.clipboard.writeText){ navigator.clipboard.writeText(text).then(done).catch(()=>{ const a=document.getElementById('copyArea'); a.value=text; a.focus(); a.select(); try{document.execCommand('copy');}catch(e){} done(); }); }
      else { const a=document.getElementById('copyArea'); a.value=text; a.focus(); a.select(); try{document.execCommand('copy');}catch(e){} done(); }
    }

    function switchTab(view){
      document.querySelectorAll('.tab').forEach(x=>x.classList.toggle('active', x.dataset.view===view));
      document.querySelectorAll('.view').forEach(x=>x.classList.toggle('active', x.id==='view-'+view));
      window.scrollTo({top:0});
    }

    document.addEventListener('click', (e) => {
      const t = e.target;
      const moveEl = t.closest('[data-moveday]');
      if(moveEl){ e.stopPropagation(); const [i,dir] = moveEl.dataset.moveday.split('|').map(Number); moveDay(i, dir); renderMine(); renderStock(); return; }
      const fillEl = t.closest('[data-fillday]');
      if(fillEl){ e.stopPropagation(); fillTarget = Number(fillEl.dataset.fillday); setMineMode('pick'); renderMine(); const ps=document.getElementById('pickSearch'); if(ps){ ps.scrollIntoView({block:'nearest'}); ps.focus(); } return; }
      const pickAddEl = t.closest('[data-pickadd]');
      if(pickAddEl){ e.stopPropagation(); addRecipeToWeek(pickAddEl.dataset.pickadd, fillTarget); fillTarget = null; renderMine(); renderRecipes(); renderStock(); return; }
      const clearEl = t.closest('[data-clearday]');
      if(clearEl){ e.stopPropagation(); clearDay(Number(clearEl.dataset.clearday)); renderMine(); renderRecipes(); renderStock(); return; }
      const addMineEl = t.closest('[data-addmine]');
      if(addMineEl){
        e.stopPropagation();
        const inRecipes = !!addMineEl.closest('#recipeList');
        const on = toggleMyWeek(addMineEl.dataset.addmine);
        if(inRecipes){ addMineEl.classList.toggle('on', on); addMineEl.textContent = on ? '✓ In my week' : '＋ Add to my week'; }
        else renderRecipes();
        renderMine(); renderStock();
        return;
      }
      const rmHaveEl = t.closest('[data-rmhave]');
      if(rmHaveEl){ removePantry(decodeURIComponent(rmHaveEl.dataset.rmhave)); renderStock(); return; }
      if(t.closest('#addAllMakeable')){ matchRecipes(getPantry()).filter(m => m.miss.length===0).forEach(m => { if(!getMyWeek().includes(m.r.id)) toggleMyWeek(m.r.id); }); renderMine(); renderStock(); renderRecipes(); return; }
      const cardH = t.closest('[data-toggle="card"]');
      if(cardH){ cardH.closest('.recipe-card').classList.toggle('open'); return; }
      const gotoEl = t.closest('[data-goto]');
      if(gotoEl){ e.stopPropagation(); gotoRecipe(gotoEl.dataset.goto); return; }
      const rmEl = t.closest('[data-rm]');
      if(rmEl){ e.stopPropagation(); removeManual(rmEl.dataset.rm); renderShop(); return; }
      const basketH = t.closest('#shopContent [data-basket]');
      if(basketH){ shopBasketOpen = !shopBasketOpen; renderShop(); return; }
      const shopIt = t.closest('#shopContent .shopitem');
      if(shopIt){ toggleCheck(shopIt.dataset.id); renderShop(); return; }
      const tab = t.closest('.tab');
      if(tab){ switchTab(tab.dataset.view); return; }
    });

    document.getElementById('addBtn').onclick = () => { const inp=document.getElementById('addInput'); const v=inp.value.trim(); if(!v) return; addManual([{item:v,qty:'',aisle:'Other'}]); inp.value=''; renderShop(); };
    document.getElementById('addInput').addEventListener('keydown', e => { if(e.key==='Enter') document.getElementById('addBtn').click(); });
    document.getElementById('uncheckBtn').onclick = () => { LS.set(checkKey(), {}); renderShop(); };
    document.getElementById('clearAddedBtn').onclick = () => { LS.set(manualKey(), []); renderShop(); };
    document.getElementById('recipeSearch').addEventListener('input', (e) => { searchQ = e.target.value.trim().toLowerCase(); renderRecipes(); });
    document.getElementById('copyBtn').onclick = () => copyText(shopText(), document.getElementById('copyBtn'), '📋 Copy list');
    document.querySelectorAll('#scopeBar button').forEach(b => { b.onclick = () => { shopScope = b.dataset.scope; LS.set('shopScope', shopScope); renderShop(); }; });
    document.getElementById('pickSearch').addEventListener('input', (e) => { pickQ = e.target.value.trim().toLowerCase(); renderPickResults(); });
    document.getElementById('mineShop').onclick = () => { shopScope='mine'; LS.set('shopScope', shopScope); renderShop(); switchTab('shop'); };
    document.querySelectorAll('.mine-modes button').forEach(b => { b.onclick = () => setMineMode(b.dataset.mmode); });
    const haveAdd = () => { const inp=document.getElementById('haveInput'); addPantry(inp.value); inp.value=''; renderStock(); };
    document.getElementById('haveAddBtn').onclick = haveAdd;
    document.getElementById('haveInput').addEventListener('keydown', e => { if(e.key==='Enter') haveAdd(); });
    document.getElementById('pullBasketBtn').onclick = () => { pantryFromBasket(); renderStock(); };
    document.getElementById('clearHaveBtn').onclick = () => { LS.set('pantry', []); renderStock(); };
    document.getElementById('haveOpts').innerHTML = allHaveNames().map(n => `<option value="${n}"></option>`).join('');

    setMineMode(LS.get('mineMode', 'pick'));
    renderMine();
    renderStock();
    renderFilters();
    renderRecipes();
    renderShop();
  </script>

  <style is:global>
    .mine-intro{ background:var(--card); border:1px solid var(--line); border-left:3px solid var(--accent); border-radius:10px; padding:12px 14px; margin-bottom:14px; font-size:.92rem; line-height:1.45; color:var(--muted); }
    .mine-modes{ display:flex; gap:8px; margin-bottom:14px; }
    .mine-modes button{ flex:1; padding:9px; border:1px solid var(--line); border-radius:10px; background:var(--card); color:var(--muted); font:inherit; font-weight:600; cursor:pointer; }
    .mine-modes button.active{ background:var(--accent); border-color:var(--accent); color:#fff; }
    .stock-note{ font-size:.88rem; color:var(--muted); line-height:1.45; margin-bottom:12px; }
    .stock-tools{ display:flex; gap:8px; margin:10px 0; }
    .chips{ display:flex; flex-wrap:wrap; gap:6px; margin-bottom:18px; }
    .chip{ display:inline-flex; align-items:center; gap:6px; padding:5px 6px 5px 11px; background:var(--card); border:1px solid var(--line); border-radius:999px; font-size:.85rem; }
    .chip button{ border:none; background:transparent; color:var(--muted); font-size:.8rem; line-height:1; padding:0 2px; cursor:pointer; }
    .chip button:hover{ color:var(--takeout); }
    .suggest{ display:flex; align-items:center; gap:10px; padding:11px 12px; margin-bottom:8px; border:1px solid var(--line); border-radius:10px; background:var(--card); }
    .suggest.can{ border-color:var(--vegan); }
    .s-title{ flex:1; font-weight:600; cursor:pointer; }
    .cov{ font-size:.78rem; color:var(--muted); white-space:nowrap; }
    .cov.ok{ color:var(--vegan); font-weight:600; }
    .suggest .minebtn{ margin:0; }
    .addall{ width:100%; padding:11px; margin-bottom:12px; border:none; border-radius:10px; background:var(--vegan); color:#fff; font:inherit; font-weight:700; cursor:pointer; }
    .mine-yourweek-h{ font-weight:700; font-size:1.05rem; margin:22px 0 10px; }
    .mine-add{ display:flex; gap:8px; margin-bottom:16px; }
    .mine-add select, .mine-add input{ flex:1; min-width:0; padding:10px; border:1px solid var(--line); border-radius:10px; background:var(--card); color:inherit; font:inherit; }
    .mine-add button{ padding:10px 16px; border:none; border-radius:10px; background:var(--accent); color:#fff; font:inherit; font-weight:600; cursor:pointer; white-space:nowrap; }
    .pick-results{ margin-bottom:16px; }
    .pick-row{ display:flex; align-items:center; gap:10px; width:100%; text-align:left; padding:11px 12px; margin-bottom:8px; border:1px solid var(--line); border-radius:10px; background:var(--card); color:inherit; font:inherit; cursor:pointer; }
    .pick-row:hover{ border-color:var(--accent); }
    .pick-row .dot{ width:10px; height:10px; border-radius:50%; flex:none; }
    .pick-row .title{ flex:1; font-weight:600; }
    .pick-row .pt{ font-size:.78rem; color:var(--muted); white-space:nowrap; }
    .pick-row .plus{ font-size:1.1rem; font-weight:700; color:var(--accent); flex:none; }
    .pick-row .inweek{ font-size:.78rem; color:var(--accent); font-weight:600; white-space:nowrap; }
    .day-slot .day-label{ font-size:.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.05em; width:30px; flex:none; }
    .day-slot.free{ display:flex; align-items:center; gap:11px; padding:12px 15px; margin-bottom:9px; border:1px dashed var(--line); border-radius:13px; }
    .day-slot.free.target{ border-color:var(--accent); background:#faf8f4; }
    .day-free{ flex:1; font-style:italic; font-size:.92rem; color:var(--muted); }
    .day-slot.free.target .day-free{ color:var(--accent); font-style:normal; font-weight:600; }
    .day-add{ flex:none; border:1px solid var(--line); border-radius:8px; background:var(--card); color:var(--accent); font:inherit; font-size:.82rem; font-weight:600; padding:6px 12px; cursor:pointer; }
    .day-add:hover{ border-color:var(--accent); }
    .day-move{ display:inline-flex; flex-direction:column; gap:2px; flex:none; }
    .day-move .dmove{ width:25px; height:17px; padding:0; border:1px solid var(--line); border-radius:5px; background:var(--card); color:var(--accent); font-size:.6rem; line-height:1; cursor:pointer; }
    .day-move .dmove:disabled{ opacity:.3; cursor:default; }
    .day-move .dmove:hover:not(:disabled){ border-color:var(--accent); }
    .mine-empty{ padding:28px 8px; text-align:center; color:var(--muted); }
    .rmmine{ border:none; background:transparent; color:var(--muted); font-size:1rem; line-height:1; padding:2px 6px; cursor:pointer; }
    .rmmine:hover{ color:var(--takeout); }
    .minebtn{ display:inline-block; margin:0 0 12px; padding:7px 12px; border:1px solid var(--accent); border-radius:8px; background:transparent; color:var(--accent); font:inherit; font-size:.85rem; font-weight:600; cursor:pointer; }
    .minebtn.on{ background:var(--accent); color:#fff; }
  </style>
</Base>
